---
// src/components/LogsTree.astro
const { logs, pathPrefix = "" } = Astro.props;

// Sort arrays alphanumeric order helper
const folderKeys = Object.keys(logs?.folders || {}).sort((a, b) =>
  a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' })
);
const fileKeys = Object.keys(logs?.files || {}).sort((a, b) =>
  a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' })
);
---

<div class="tree-wrapper">
  {/* Render Files across all branches at any level */}
  {fileKeys.map((fileSlug) => {
    const completePathKey = pathPrefix ? `${pathPrefix}/${fileSlug}` : fileSlug;
    return (
      <div 
        class="day-item" 
        data-pathkey={completePathKey}
      >
        {fileSlug}.log
      </div>
    );
  })}

  {/* Render Folders up to 10 levels deep */}
  {folderKeys.map((folderName) => {
    const nextPrefix = pathPrefix ? `${pathPrefix}/${folderName}` : folderName;
    const folderUniqueKey = `folder-${nextPrefix.replace(/\//g, '-')}`;
    
    return (
      <div class="tree-folder-group">
        <div class="folder-item" data-folder data-key={folderUniqueKey}>
          <span class="arrow">&gt;</span> {folderName}
        </div>
        <div id={folderUniqueKey} class="tree-children">
          <Astro.self logs={logs.folders[folderName]} pathPrefix={nextPrefix} />
        </div>
      </div>
    );
  })}
</div>

<style>
  /* Keeps all original styling rules intact while handling indentations */
  .tree-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: monospace;
    user-select: none;
  }
  .folder-item, .day-item {
    cursor: pointer;
    padding: 2px 6px;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .folder-item:hover, .day-item:hover {
    background: rgba(255, 255, 255, 0.05);
  }
  .day-item.selected {
    color: var(--bright-green, #9c0fc7);
    background: rgba(247, 0, 255, 0.1);
  }
  .tree-children {
    display: none;
    padding-left: 14px; /* Creates perfectly structured indentation across nested trees */
    border-left: 1px dashed #222;
    margin-left: 9px;
  }
  .tree-children.open {
    display: flex;
    flex-direction: column;
  }
  .arrow {
    width: 10px;
    display: inline-block;
    color: #9c0fc7;
  }
</style>