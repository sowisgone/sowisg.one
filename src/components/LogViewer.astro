---
// LogViewer.astro
// Renders the right-side log content panel.
// Content is injected client-side via the blog page script.
---

<div class="log-viewer-inner" style="display:flex;flex-direction:column;height:100%;">
  <p class="prompt">sow@sow:~$ <span id="log-cmd">./day.log</span></p>
  <div id="log-viewer" style="flex:1;overflow-y:auto;">
    <div class="empty-state">
      <em>// </em>select a log file to read its contents
    </div>
  </div>
</div>

<style>
  .empty-state {
    color: #2a2a2a;
    font-size: 12px;
    padding-top: 8px;
  }

  .empty-state em {
    color: var(--dim-green);
    font-style: normal;
  }

  /* ── formatted log content ───────────────────────────── */
  :global(.log-content) {
    font-size: 13px;
    line-height: 1.75;
    color: #ccc;
  }

  :global(.log-content h1) {
    font-family: 'VT323', monospace;
    font-size: 28px;
    font-weight: normal;
    color: var(--pink);
    letter-spacing: 2px;
    margin-bottom: 4px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
  }

  :global(.log-content h2) {
    font-family: 'VT323', monospace;
    font-size: 20px;
    font-weight: normal;
    color: var(--pink);
    letter-spacing: 1px;
    margin: 16px 0 6px;
  }

  :global(.log-content h3) {
    font-size: 12px;
    color: var(--pink);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 12px 0 4px;
  }

  :global(.log-content p)    { margin-bottom: 8px; }
  :global(.log-content a)    { color: var(--pink); text-decoration: none; }
  :global(.log-content a:hover) { text-decoration: underline; }

  :global(.log-content ul)   { list-style: none; margin: 6px 0 10px; }
  :global(.log-content ul li) { padding: 1px 0; color: #ccc; }
  :global(.log-content ul li::before) { content: '~ '; color: var(--green); }

  :global(.log-content ol)   { list-style: none; counter-reset: ol; margin: 6px 0 10px; }
  :global(.log-content ol li) { counter-increment: ol; padding: 1px 0; color: #ccc; }
  :global(.log-content ol li::before) { content: counter(ol) '. '; color: var(--pink); }

  :global(.log-content code) {
    background: #111;
    border: 1px solid #1e1e1e;
    padding: 1px 5px;
    color: var(--pink);
    font-size: 12px;
  }

  :global(.log-content pre) {
    background: #0d0d0d;
    border: 1px solid #1e1e1e;
    padding: 12px;
    margin: 10px 0;
    overflow-x: auto;
    font-size: 12px;
    color: #aaa;
    line-height: 1.5;
  }

  :global(.log-content pre code) { background: none; border: none; padding: 0; }

  :global(.log-content blockquote) {
    border-left: 2px solid var(--dim-green);
    padding-left: 12px;
    color: #777;
    margin: 8px 0;
    font-style: italic;
  }

  :global(.log-content img) {
    max-width: 100%;
    border: 1px solid var(--border);
    margin: 8px 0;
  }

  :global(.log-content hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 16px 0;
  }

  :global(.log-content table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    margin: 10px 0;
  }

  :global(.log-content th) {
    border-bottom: 1px solid var(--border);
    color: var(--pink);
    text-align: left;
    padding: 4px 8px;
  }

  :global(.log-content td) {
    border-bottom: 1px solid #181818;
    padding: 4px 8px;
    color: #bbb;
  }

  /* ── dropdowns ───────────────────────────────────────── */
  :global(.log-content details.log-toggle) {
    border-left: 2px solid #2a2a2a;
    margin: 6px 0;
    padding-left: 10px;
  }

  :global(.log-content details.log-toggle[open]) {
    border-left-color: var(--dim-green);
  }

  :global(.log-content summary.log-toggle-label) {
    cursor: pointer;
    color: var(--pink);
    font-size: 13px;
    /* list-style + display:flex together kill the native marker on all browsers */
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 2px 0;
    user-select: none;
  }

  /* Belt AND suspenders — kill the native marker every way possible */
  :global(.log-content summary.log-toggle-label::-webkit-details-marker) { display: none; }
  :global(.log-content summary.log-toggle-label::marker) { content: ''; font-size: 0; }

  /* Our own arrow — the only > that should appear */
  :global(.log-content summary.log-toggle-label::before) {
    content: '>';
    color: var(--dim-green);
    font-family: monospace;
    display: inline-block;
    flex-shrink: 0;
  }

  :global(.log-content details.log-toggle[open] > summary.log-toggle-label::before) {
    content: 'v';
  }

  :global(.log-content summary.log-toggle-label:hover) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  :global(.log-content details.log-toggle > *:not(summary)) {
    margin-top: 6px;
    color: #aaa;
  }

  /* ── equations (KaTeX) ───────────────────────────────── */
:global(.log-content .log-equation) {
  margin: 12px 0;
  color: #ccc;
}


  :global(.log-content .log-equation .katex) {
    color: #ccc;
    font-size: 1.4em;
  }

  :global(.log-meta) { font-size: 11px; color: #444; margin-bottom: 12px; }

  :global(.tag) {
    display: inline-block;
    background: #0d0014;
    border: 1px solid var(--dim-green);
    color: var(--green);
    font-size: 11px;
    padding: 1px 7px;
    margin-right: 4px;
    margin-top: 4px;
  }
</style>