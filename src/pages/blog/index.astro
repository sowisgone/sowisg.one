---
// src/pages/blog/index.astro
// Reads all log entries from src/content/logs up to 10 levels deep.
// Organizes files/folders by alphanumeric order (0-9 then a-z) across all tree branches.

import { readFileSync, readdirSync, statSync, existsSync } from 'node:fs';
import { join, relative } from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Panel from '../../components/Panel.astro';
import LogsTree from '../../components/LogsTree.astro';
import LogViewer from '../../components/LogViewer.astro';
import { cleanNotionHtml } from '../../scripts/cleanNotionHtml';

const LOGS_DIR = join(process.cwd(), 'src/content/logs');

type DayEntry = { title: string; tags: string[]; content: string };

// Custom alphanumeric sort matching your precise sequence requirements (0-9 before a-z)
function alphanumericSort(a: string, b: string): number {
  return a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' });
}

// 1. Build a flattened object database so the client-side log-viewer click script still finds files instantly
const logsFlatMap: Record<string, DayEntry> = {};

function buildLogsTreeData(dirPath: string, currentDepth: number = 1): any {
  if (currentDepth > 10 || !existsSync(dirPath)) return null;

  const currentLevelItems: any = { folders: {}, files: {} };
  const items = readdirSync(dirPath).sort(alphanumericSort);

  for (const item of items) {
    if (item.startsWith('.')) continue;

    const fullPath = join(dirPath, item);
    const stat = statSync(fullPath);

    if (stat.isDirectory()) {
      const subdirectoryData = buildLogsTreeData(fullPath, currentDepth + 1);
      if (subdirectoryData) {
        currentLevelItems.folders[item] = subdirectoryData;
      }
    } else if (item.endsWith('.html')) {
      const slug = item.replace('.html', '');
      const raw = readFileSync(fullPath, 'utf-8');
      const cleanContent = cleanNotionHtml(raw);

      // Save file contents into the flattened dataset using a unique path-based identifier
      const relativePathKey = relative(LOGS_DIR, fullPath).replace(/\\/g, '/').replace('.html', '');
      logsFlatMap[relativePathKey] = cleanContent;
      
      currentLevelItems.files[slug] = cleanContent;
    }
  }

  return currentLevelItems;
}

const rawTreeStructure = buildLogsTreeData(LOGS_DIR);

// Convert standard hierarchical lookups safely back to a structure LogsTree can interpret without crashing
// Note: We populate placeholder top tiers to prevent old legacy visual dependencies from throwing property errors
const logsTree = rawTreeStructure?.folders || {};
const logsJson = JSON.stringify(logsFlatMap);
---

<Layout title="sow@sow:~$ ./log">
  <div class="blog-grid">

    <Panel title="dates.json">
      <LogsTree logs={rawTreeStructure} />
    </Panel>

    <Panel title="day.log">
      <LogViewer />
    </Panel>

  </div>
</Layout>

<script define:vars={{ logsJson }}>
  const logs = JSON.parse(logsJson);

  // ── audio ─────────────────────────────────────────────────
  const clickSound = new Audio('../audio/mouse.mp3');
  function playClick() {
    try { clickSound.currentTime = 0; clickSound.play(); } catch {}
  }

  // ── dot navigation (back to home) ─────────────────────────
  document.querySelectorAll('.dots span').forEach(dot => {
    dot.addEventListener('click', e => {
      e.stopPropagation();
      playClick();
      if (dot.classList.contains('d1') || dot.classList.contains('d3')) {
        setTimeout(() => { window.location.href = '../'; }, 100);
      }
    });
  });

  // ── folder toggle ─────────────────────────────────────────
  function toggleFolder(folderEl, childrenEl) {
    const isOpen = childrenEl.classList.toggle('open');
    folderEl.classList.toggle('open', isOpen);
    const arrow = folderEl.querySelector('.arrow');
    if (arrow) arrow.textContent = isOpen ? 'v' : '>';
  }

  // Use event delegation to handle clicks up to 10 levels seamlessly
  document.body.addEventListener('click', e => {
    const folder = e.target.closest('[data-folder]');
    if (!folder) return;
    
    e.stopPropagation();
    playClick();
    const key = folder.getAttribute('data-key');
    const children = document.getElementById(key);
    if (children) toggleFolder(folder, children);
  });

  // seed open-state arrows for any pre-opened folders
  document.querySelectorAll('.tree-children.open').forEach(openChildren => {
    const folder = openChildren.previousElementSibling;
    if (folder) {
      folder.classList.add('open');
      const arrow = folder.querySelector('.arrow');
      if (arrow) arrow.textContent = 'v';
    }
  });

  // ── log viewer ────────────────────────────────────────────
  function openLog(pathKey, dayEl) {
    document.querySelectorAll('.day-item').forEach(d => d.classList.remove('selected'));
    dayEl.classList.add('selected');

    const entry = logs[pathKey];
    if (!entry) return;

    document.getElementById('log-cmd').textContent = `./logs/${pathKey}.log`;

    const tagsHtml = (entry.tags?.length)
      ? `<p style="margin-top:12px">${entry.tags.map(t => `<span class="tag">#${t}</span>`).join('')}</p>`
      : '';

    document.getElementById('log-viewer').innerHTML =
      `<div class="log-content">${entry.content}${tagsHtml}</div>`;
  }

  document.body.addEventListener('click', e => {
    const dayEl = e.target.closest('.day-item');
    if (!dayEl) return;

    e.stopPropagation();
    playClick();
    // Read the explicit pathKey generated directly by the recursive tree loops
    openLog(dayEl.dataset.pathkey, dayEl);
  });
</script>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 14.4px;
    max-width: 990px;
    margin: 0 auto;
    height: calc(100vh - 43.2px);
  }

  /* Panels fill height and scroll internally */
  .blog-grid :global(.panel) {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .blog-grid :global(.panel-body) {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--dim-green) #111;
  }

  .blog-grid :global(.panel-body::-webkit-scrollbar)            { width: 4px; }
  .blog-grid :global(.panel-body::-webkit-scrollbar-track)       { background: #0a0a0a; }
  .blog-grid :global(.panel-body::-webkit-scrollbar-thumb)       { background: #222; }
  .blog-grid :global(.panel-body::-webkit-scrollbar-thumb:hover) { background: var(--dim-green); }

  @media (max-width: 700px) {
    .blog-grid {
      grid-template-columns: 1fr;
      height: auto;
    }
    .blog-grid :global(.panel)            { height: 300px; }
    .blog-grid :global(.panel:last-child) { height: auto; min-height: 400px; }
  }
</style>